---
/**
 * SourceDocuments.astro — Download links for hosted vote record PDFs.
 *
 * Renders a list of PDF source documents with download icons, links to
 * the hosted copy, and optional link to the original source URL.
 * Designed for the "Leyes Pro-Crimen" section where original scanned
 * vote records are hosted for public transparency.
 *
 * @prop {SourceDocument[]} documents — Array of source document references.
 */

import type { SourceDocument } from '../data/types';

interface Props {
  documents: SourceDocument[];
}

const { documents } = Astro.props;
---

{documents.length > 0 && (
  <div class="mt-4 rounded-lg border border-slate-200 bg-slate-50 p-4">
    <h4 class="mb-3 flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-slate-500">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m.75 12l3 3m0 0l3-3m-3 3v-6m-1.5-9H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
      </svg>
      Documentos fuente
    </h4>
    <ul class="space-y-2">
      {documents.map((doc) => (
        <li class="flex flex-wrap items-start gap-2 text-sm">
          <a
            href={doc.path}
            target="_blank"
            rel="noopener noreferrer"
            class="font-medium text-blue-700 underline decoration-blue-300 hover:text-blue-900"
          >
            {doc.label}
          </a>
          {doc.sourceUrl && (
            <a
              href={doc.sourceUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs text-slate-400 hover:text-slate-600"
              title="Enlace original en congreso.gob.pe"
            >
              (fuente original)
            </a>
          )}
        </li>
      ))}
    </ul>
  </div>
)}
