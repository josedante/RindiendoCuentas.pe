---
/**
 * VoteStages.astro — Multi-stage vote display with tabs.
 *
 * Renders a tabbed interface where each tab corresponds to a stage
 * in the legislative process (primera votación, segunda votación,
 * insistencia, etc.). Each tab shows its own VoteDisplay (chart/table toggle).
 *
 * Also displays a summary strip with aggregate totals per stage.
 *
 * @prop {VoteStage[]} stages — Array of vote stages in chronological order.
 * @prop {string} lawId — Unique law identifier for scoping DOM elements.
 */

import type { VoteStage } from '../data/types';
import VoteDisplay from './VoteDisplay.astro';

interface Props {
  stages: VoteStage[];
  lawId: string;
}

const { stages, lawId } = Astro.props;

const venueLabels: Record<string, string> = {
  pleno: 'Pleno',
  'comision-permanente': 'Comisión Permanente',
};

function formatDate(iso: string): string {
  return new Date(iso + 'T12:00:00').toLocaleDateString('es-PE', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  });
}

function getStageTotals(stage: VoteStage) {
  return stage.votes.reduce(
    (acc, v) => ({
      aFavor: acc.aFavor + v.aFavor,
      enContra: acc.enContra + v.enContra,
      abstencion: acc.abstencion + v.abstencion,
    }),
    { aFavor: 0, enContra: 0, abstencion: 0 },
  );
}
---

{stages.length > 1 ? (
  <div class="vote-stages mt-6" data-stages-id={lawId}>
    {/* Stage summary strip */}
    <div class="mb-4 grid gap-2 sm:grid-cols-{stages.length}">
      {stages.map((stage) => {
        const totals = getStageTotals(stage);
        return (
          <div class="rounded-lg border border-slate-100 bg-white px-3 py-2 text-center">
            <p class="text-xs font-semibold text-slate-500">{stage.label}</p>
            <p class="text-xs text-slate-400">{formatDate(stage.date)} · {venueLabels[stage.venue] ?? stage.venue}</p>
            <div class="mt-1 flex items-center justify-center gap-2 text-sm">
              <span class="font-bold text-emerald-700">{totals.aFavor}</span>
              {totals.enContra > 0 && (
                <span class="font-bold text-rose-600">-{totals.enContra}</span>
              )}
              {totals.abstencion > 0 && (
                <span class="font-bold text-amber-600">{totals.abstencion} abs.</span>
              )}
            </div>
          </div>
        );
      })}
    </div>

    {/* Stage tabs */}
    <div class="mb-4 flex flex-wrap gap-1 rounded-lg bg-slate-100 p-1" role="tablist" aria-label="Etapas de votación">
      {stages.map((stage, i) => (
        <button
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          class={`stage-tab flex-1 rounded-md px-3 py-2 text-xs font-medium transition-colors sm:text-sm ${i === 0 ? 'active-stage-tab' : ''}`}
          data-stage-target={`${lawId}-stage-${i}`}
        >
          {stage.label}
        </button>
      ))}
    </div>

    {/* Stage panels */}
    {stages.map((stage, i) => (
      <div
        class={`stage-panel ${i !== 0 ? 'hidden' : ''}`}
        data-stage-panel={`${lawId}-stage-${i}`}
      >
        <VoteDisplay votes={stage.votes} lawId={`${lawId}-stage-${i}`} />
      </div>
    ))}
  </div>
) : stages.length === 1 ? (
  <VoteDisplay votes={stages[0].votes} lawId={lawId} />
) : null}

<style>
  .stage-tab {
    color: var(--color-slate-500);
    background: transparent;
  }
  .stage-tab.active-stage-tab {
    color: var(--color-slate-900);
    background: white;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.06);
  }
</style>

<script>
  document.querySelectorAll('.vote-stages').forEach((container) => {
    const tabs = container.querySelectorAll('.stage-tab');
    const panels = container.querySelectorAll('.stage-panel');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = (tab as HTMLElement).dataset.stageTarget;

        tabs.forEach((t) => {
          t.classList.remove('active-stage-tab');
          t.setAttribute('aria-selected', 'false');
        });
        tab.classList.add('active-stage-tab');
        tab.setAttribute('aria-selected', 'true');

        panels.forEach((p) => {
          const panel = p as HTMLElement;
          if (panel.dataset.stagePanel === target) {
            panel.classList.remove('hidden');
          } else {
            panel.classList.add('hidden');
          }
        });
      });
    });
  });
</script>
