---
/**
 * ComparisonChart.astro — Cross-law comparison grouped bar chart.
 *
 * Shows how each parliamentary group voted across laws (default: 5 gasto laws),
 * enabling readers to spot patterns of consistent support, opposition, or
 * selective abstention. Optional props override data for other informes.
 *
 * Renders a grouped bar chart (one group per party, one bar per law)
 * showing "A Favor" votes. A secondary toggle switches to
 * "En Contra + Abstención" view for dissent analysis.
 */

import { laws as defaultLaws, partyNames as defaultPartyNames } from '../data/laws';
import type { Law } from '../data/types';

const defaultLawColors = [
  '#1e40af',
  '#059669',
  '#d97706',
  '#dc2626',
  '#7c3aed',
];

interface Props {
  laws?: Law[];
  partyNames?: string[];
  sectionId?: string;
  heading?: string;
  description?: string;
  chartCanvasId?: string;
  ariaLabel?: string;
  lawColors?: string[];
}

const {
  laws: lawsProp,
  partyNames: partyNamesProp,
  sectionId = 'comparacion',
  heading = 'Comparación entre Leyes',
  description = 'Votos «A Favor» de cada grupo parlamentario en las 5 leyes analizadas.',
  chartCanvasId = 'comparison-chart',
  ariaLabel = 'Gráfico comparativo de votaciones entre las leyes analizadas',
  lawColors: lawColorsProp,
} = Astro.props;

const lawsData = lawsProp ?? defaultLaws;
const partiesData = partyNamesProp ?? defaultPartyNames;
const lawColors =
  lawColorsProp ?? defaultLawColors.slice(0, Math.max(1, lawsData.length));

const comparisonData = JSON.stringify({
  parties: partiesData,
  laws: lawsData.map((law) => ({
    id: law.id,
    shortName: law.shortName,
    votes: partiesData.map((name) => {
      const pv = law.votes.find((v) => v.party === name);
      return {
        aFavor: pv?.aFavor ?? 0,
        enContra: pv?.enContra ?? 0,
        abstencion: pv?.abstencion ?? 0,
      };
    }),
  })),
});
---

<section id={sectionId} class="comparison-chart-root scroll-mt-20 py-12">
  <h2 class="mb-2 text-2xl font-bold text-slate-900 lg:text-3xl">
    {heading}
  </h2>
  <p class="mb-6 text-sm text-slate-500">
    {description}
  </p>

  <!-- View mode toggle -->
  <div class="mb-4 flex gap-1 rounded-lg bg-slate-100 p-1" role="tablist" aria-label="Modo de comparación">
    <button
      role="tab"
      aria-selected="true"
      class="comparison-mode-tab active-comparison-tab flex-1 rounded-md px-4 py-2 text-sm font-medium transition-colors"
      data-mode="favor"
    >
      Votos a Favor
    </button>
    <button
      role="tab"
      aria-selected="false"
      class="comparison-mode-tab flex-1 rounded-md px-4 py-2 text-sm font-medium transition-colors"
      data-mode="dissent"
    >
      Disidencia (Contra + Abstención)
    </button>
  </div>

  <div
    class="comparison-chart-wrapper rounded-xl border border-slate-200 bg-white p-4 shadow-sm"
    data-comparison={comparisonData}
    data-colors={JSON.stringify(lawColors)}
  >
    <canvas
      id={chartCanvasId}
      class="w-full"
      role="img"
      aria-label={ariaLabel}
    ></canvas>
  </div>
</section>

<style>
  .comparison-mode-tab {
    color: var(--color-slate-500);
    background: transparent;
  }
  .comparison-mode-tab.active-comparison-tab {
    color: var(--color-slate-900);
    background: white;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.06);
  }
</style>

<script>
  import { Chart, registerables } from 'chart.js';
  Chart.register(...registerables);

  interface CompLaw {
    id: string;
    shortName: string;
    votes: { aFavor: number; enContra: number; abstencion: number }[];
  }
  interface CompData {
    parties: string[];
    laws: CompLaw[];
  }

  document.querySelectorAll('.comparison-chart-root').forEach((root) => {
    const wrapper = root.querySelector('.comparison-chart-wrapper') as HTMLElement | null;
    if (!wrapper) return;

    const data: CompData = JSON.parse(wrapper.dataset.comparison || '{}');
    const colors: string[] = JSON.parse(wrapper.dataset.colors || '[]');
    const canvas = wrapper.querySelector('canvas') as HTMLCanvasElement | null;
    if (!canvas) return;

    const shortParties = data.parties.map((p) =>
      p.length > 22 ? p.substring(0, 19) + '…' : p,
    );

    canvas.style.height = `${data.parties.length * 46 + 80}px`;

    function buildDatasets(mode: 'favor' | 'dissent') {
      return data.laws.map((law, i) => ({
        label: law.shortName,
        data: law.votes.map((v) =>
          mode === 'favor' ? v.aFavor : v.enContra + v.abstencion,
        ),
        backgroundColor: colors[i] + (mode === 'dissent' ? '99' : ''),
        borderColor: colors[i],
        borderWidth: 1,
        borderRadius: 3,
      }));
    }

    const chart = new Chart(canvas, {
      type: 'bar',
      data: {
        labels: shortParties,
        datasets: buildDatasets('favor'),
      },
      options: {
        indexAxis: 'y',
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            position: 'top',
            labels: {
              font: { family: 'Inter, system-ui, sans-serif', size: 11 },
              padding: 12,
              usePointStyle: true,
              pointStyle: 'rectRounded',
            },
          },
          tooltip: {
            callbacks: {
              title: (items) => data.parties[items[0].dataIndex] || '',
            },
          },
        },
        scales: {
          x: {
            ticks: {
              stepSize: 2,
              font: { family: 'Inter, system-ui, sans-serif', size: 11 },
            },
            grid: { color: '#e2e8f0' },
          },
          y: {
            ticks: {
              font: { family: 'Inter, system-ui, sans-serif', size: 11 },
            },
            grid: { display: false },
          },
        },
      },
    });

    root.querySelectorAll('.comparison-mode-tab').forEach((tab) => {
      tab.addEventListener('click', () => {
        const mode = (tab as HTMLElement).dataset.mode as 'favor' | 'dissent';

        root.querySelectorAll('.comparison-mode-tab').forEach((t) => {
          t.classList.remove('active-comparison-tab');
          t.setAttribute('aria-selected', 'false');
        });
        tab.classList.add('active-comparison-tab');
        tab.setAttribute('aria-selected', 'true');

        chart.data.datasets = buildDatasets(mode);
        chart.update();
      });
    });
  });
</script>
