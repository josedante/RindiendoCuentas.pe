---
/**
 * CaseSection.astro — Wrapper for antejuicio / blindaje cases (non-law informes).
 *
 * Same visual rhythm as LawSection: numbered anchor, title, summary card, slot.
 * Chips: parliamentary instance (SAC, Comisión Permanente, Pleno) and vote date.
 */

import type { BlindajeVenue } from '../data/types';

interface Props {
  id: string;
  shortName: string;
  fullName: string;
  date: string;
  venue: BlindajeVenue;
  resultLine: string;
  index: number;
  resultLabel?: string;
}

const {
  id,
  shortName,
  fullName,
  date,
  venue,
  resultLine,
  index,
  resultLabel = 'Resultado',
} = Astro.props;

const formattedDate = new Date(date + 'T12:00:00').toLocaleDateString('es-PE', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const venueLabel: Record<BlindajeVenue, string> = {
  sac: 'Subcomisión de Acusaciones (SAC)',
  'comision-permanente': 'Comisión Permanente',
  pleno: 'Pleno del Congreso',
};

const venueClass: Record<BlindajeVenue, string> = {
  sac: 'bg-emerald-100 text-emerald-900',
  'comision-permanente': 'bg-violet-100 text-violet-900',
  pleno: 'bg-slate-200 text-slate-800',
};
---

<section id={id} class="scroll-mt-20 py-12">
  <div class="mb-6 flex items-baseline gap-3">
    <span
      class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-slate-900 text-sm font-bold text-white"
    >
      {index}
    </span>
    <div>
      <h2 class="text-2xl font-bold text-slate-900 lg:text-3xl">{shortName}</h2>
      <p class="mt-1 text-sm text-slate-500">{fullName}</p>
    </div>
  </div>

  <div class="mb-8 rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
    <div class="flex flex-wrap gap-3 text-sm">
      <span class={`rounded-full px-3 py-1 font-medium ${venueClass[venue]}`}>
        {venueLabel[venue]}
      </span>
      <span class="rounded-full bg-slate-100 px-3 py-1 text-slate-600">
        {formattedDate}
      </span>
    </div>
    <p class="mt-4 text-sm leading-relaxed text-slate-600">
      <span class="font-semibold text-slate-800">{resultLabel}:</span>{' '}
      {resultLine}
    </p>
  </div>

  <slot />
</section>
