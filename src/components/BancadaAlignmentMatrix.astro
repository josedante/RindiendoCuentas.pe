---
/**
 * Pearson correlation matrix between bancadas (co-voting). Accessible table with
 * background shading: green = more aligned, red = opposite, neutral = weak.
 */
interface Props {
  partyIds: string[];
  idToDisplay: Record<string, string>;
  correlationMatrix: (number | null)[][];
  minSharedVotes: number;
}

const { partyIds, idToDisplay, correlationMatrix, minSharedVotes } = Astro.props;

function cellStyle(r: number | null, isDiagonal: boolean): string {
  if (isDiagonal) return 'background-color: rgb(15 23 42); color: white; font-weight: 600';
  if (r === null) return 'background-color: rgb(241 245 249); color: rgb(100 116 139)';
  const mag = Math.abs(r);
  const sat = 35 + mag * 45;
  const light = 92 - mag * 34;
  const hue = r >= 0 ? 152 : 2;
  return `background-color: hsl(${hue}deg ${sat}% ${light}%); color: rgb(15 23 42)`;
}

function formatR(r: number | null, isDiagonal: boolean): string {
  if (isDiagonal) return '1';
  if (r === null) return '—';
  return r.toFixed(2);
}
---

<div class="overflow-x-auto rounded-lg border border-slate-200 shadow-sm">
  <table class="min-w-[640px] border-collapse text-xs sm:text-sm">
    <thead>
      <tr>
        <th
          scope="col"
          class="sticky left-0 z-10 border-b border-r border-slate-200 bg-slate-50 px-2 py-2 text-left font-semibold text-slate-700"
        >
          Bancada
        </th>
        {partyIds.map((pid) => (
          <th
            scope="col"
            class="max-w-[7rem] border-b border-slate-200 bg-slate-50 px-1 py-2 text-center align-bottom font-semibold text-slate-700 [writing-mode:vertical-rl] sm:max-w-none sm:px-2 sm:[writing-mode:horizontal]"
            title={idToDisplay[pid] ?? pid}
          >
            <span class="line-clamp-3 sm:line-clamp-none">{idToDisplay[pid] ?? pid}</span>
          </th>
        ))}
      </tr>
    </thead>
    <tbody>
      {partyIds.map((rowId, i) => (
        <tr>
          <th
            scope="row"
            class="sticky left-0 z-10 border-b border-r border-slate-200 bg-white px-2 py-1.5 text-left font-medium text-slate-800"
          >
            {idToDisplay[rowId] ?? rowId}
          </th>
          {partyIds.map((colId, j) => {
            const isDiag = i === j;
            const r = isDiag ? 1 : correlationMatrix[i][j];
            return (
              <td
                class="border-b border-slate-100 px-1 py-1.5 text-center tabular-nums"
                style={cellStyle(isDiag ? 1 : r, isDiag)}
              >
                {formatR(isDiag ? 1 : r, isDiag)}
              </td>
            );
          })}
        </tr>
      ))}
    </tbody>
  </table>
</div>

<p class="mt-3 text-xs text-slate-500">
  Celdas «—»: menos de {minSharedVotes} votaciones en las que ambas bancadas tienen
  dato. La diagonal es 1 (correlación consigo misma).
</p>
