<script>
  import { Chart, registerables } from 'chart.js';
  Chart.register(...registerables);

  interface StageSummary {
    label: string;
    date: string;
    aFavor: number;
    enContra: number;
    abstencion: number;
  }

  interface LawSummary {
    shortName: string;
    lawNumber: string | null;
    stages: StageSummary[];
  }

  const wrapper = document.querySelector('[data-blindaje-summary]') as HTMLElement | null;
  const canvas = document.getElementById('summary-chart-blindaje') as HTMLCanvasElement | null;
  if (wrapper && canvas) {
    const laws: LawSummary[] = JSON.parse(wrapper.dataset.summary || '[]');

    const labels: string[] = [];
    const aFavorData: number[] = [];
    const enContraData: number[] = [];
    const abstencionData: number[] = [];

    laws.forEach((law) => {
      law.stages.forEach((stage) => {
        const lawLabel = law.lawNumber ? `Ley ${law.lawNumber}` : law.shortName;
        labels.push(`${lawLabel}\n${stage.label}`);
        aFavorData.push(stage.aFavor);
        enContraData.push(stage.enContra);
        abstencionData.push(stage.abstencion);
      });
    });

    canvas.style.height = `${labels.length * 36 + 80}px`;

    new Chart(canvas, {
      type: 'bar',
      data: {
        labels,
        datasets: [
          {
            label: 'A Favor',
            data: aFavorData,
            backgroundColor: '#059669',
            borderRadius: 3,
          },
          {
            label: 'En Contra',
            data: enContraData,
            backgroundColor: '#e11d48',
            borderRadius: 3,
          },
          {
            label: 'Abstención',
            data: abstencionData,
            backgroundColor: '#f59e0b',
            borderRadius: 3,
          },
        ],
      },
      options: {
        indexAxis: 'y',
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            position: 'top',
            labels: {
              font: { family: 'Inter, system-ui, sans-serif', size: 12 },
              padding: 16,
              usePointStyle: true,
              pointStyle: 'rectRounded',
            },
          },
        },
        scales: {
          x: {
            stacked: true,
            ticks: {
              stepSize: 10,
              font: { family: 'Inter, system-ui, sans-serif', size: 11 },
            },
            grid: { color: '#e2e8f0' },
          },
          y: {
            stacked: true,
            ticks: {
              font: { family: 'Inter, system-ui, sans-serif', size: 10 },
              autoSkip: false,
            },
            grid: { display: false },
          },
        },
      },
    });
  }
</script>
