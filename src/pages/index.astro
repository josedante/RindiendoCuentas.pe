---
/**
 * index.astro — Site hub (route: /).
 *
 * Entry point that presents both investigations with equal prominence. Longform reports live at
 * /leyes-de-gasto and /leyes-procrimen. Header nav links to those routes; logo also returns here.
 * Skip link targets #main-content (see Layout skipTargetId).
 */

import Layout from '../components/Layout.astro';
import Header from '../components/Header.astro';
import SiteHome from '../components/SiteHome.astro';
import Footer from '../components/Footer.astro';

const hubTitle = 'RindiendoCuentas.pe — Votaciones del Congreso';
const hubDescription =
  'Informes interactivos sobre votaciones del Pleno del Congreso peruano: leyes de expansión del gasto público (marzo 2026) y leyes pro-crimen (2023–2024).';
---

<Layout title={hubTitle} description={hubDescription} skipTargetId="main-content">
  <Header showMobileToc={false} />
  <div class="pt-16">
    <main id="main-content">
      <SiteHome />
    </main>
    <Footer variant="site" />
  </div>
</Layout>
