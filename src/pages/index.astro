---
/**
 * index.astro — Site hub (route: /).
 *
 * Entry point that presents informes with equal prominence. Longform reports live at
 * /leyes-de-gasto, /leyes-procrimen, /contrarreforma-universitaria, /blindaje-institucional y síntesis /alineacion-bancadas. Header links those routes;
 * logo returns here.
 * Skip link targets #main-content (see Layout skipTargetId).
 */

import Layout from '../components/Layout.astro';
import Header from '../components/Header.astro';
import SiteHome from '../components/SiteHome.astro';
import Footer from '../components/Footer.astro';

const hubTitle = 'RindiendoCuentas.pe — Votaciones del Congreso';
const hubDescription =
  'Informes interactivos sobre votaciones del Congreso peruano: gasto público (marzo 2026), leyes pro-crimen (2023–2024), contrarreforma universitaria (2022–2025), blindaje institucional (2023–2026) y síntesis de alineación entre bancadas.';
---

<Layout title={hubTitle} description={hubDescription} skipTargetId="main-content">
  <Header showMobileToc={false} />
  <div class="pt-16">
    <main id="main-content">
      <SiteHome />
    </main>
    <Footer variant="site" />
  </div>
</Layout>
